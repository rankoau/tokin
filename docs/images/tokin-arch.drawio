        <mxCell id="3rJstIUwe-mpcvYpoVB0-2" parent="N1oQfP46GQ1lDOvrroKS-53" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#999999;fontColor=#999999;opacity=70;" value="JSON-RPC API&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(153, 153, 153), rgb(106, 106, 106));&quot;&gt;(https://mainnet&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(153, 153, 153), rgb(106, 106, 106));&quot;&gt;.base.org)&lt;/span&gt;" vertex="1">
